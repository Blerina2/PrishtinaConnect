rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /channels/{channelId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.endsWith('@uni-pr.edu');

      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.token.email.endsWith('@uni-pr.edu')
          && (resource.data.allowedDepartment == 'ALL' || request.auth.token.department == resource.data.allowedDepartment);
      }
    }

    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email.endsWith('@uni-pr.edu');

      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.token.email.endsWith('@uni-pr.edu')
          && (resource.data.allowedDept == 'ALL' || request.auth.token.department == resource.data.allowedDept);
      }
    }
  }
}